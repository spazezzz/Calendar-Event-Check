# Calendar-Event-Check — Environment Variables
# Copy to .env for local dev. Set in Routine → Environment for Claude Web.
# NEVER commit .env

# ── GitHub (required) ───────────────────────────────────────
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=Calendar-Event-Check

# ── Google Calendar (optional) ──────────────────────────────
# Auth handled by Google Calendar connector — no OAuth creds needed.
# Use "primary" for main calendar, or name@group.calendar.google.com
GOOGLE_CALENDAR_ID=primary

# ── LINE Messaging API (optional) ───────────────────────────
# If absent, LINE step is skipped. Skill still completes normally.
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_TO=your_line_user_or_group_id_here
