# Calendar-Slack-Notify — Environment Variables
# Copy to .env for local dev. Set in Routine → Environment for Claude Web.
# NEVER commit .env

# ── Google Calendar (optional) ──────────────────────────────
# Auth handled by Google Calendar connector — no OAuth creds needed.
# Use "primary" for main calendar (default), or name@group.calendar.google.com
GOOGLE_CALENDAR_ID=primary
